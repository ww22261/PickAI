# PickAI 环境变量配置
# 复制此文件为 .env 并填入你的API密钥

# 火山引擎 DeepSeek API配置 (必填)
# 获取地址: https://console.volcengine.com/ark
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DEEPSEEK_MODEL=deepseek-v3-2-251201

# 服务器端口 (可选)
PORT=3000

# 拼多多API配置 (可选)
# 获取地址: https://jinbao.pinduoduo.com
PDD_CLIENT_ID=your-pdd-client-id-here
PDD_CLIENT_SECRET=your-pdd-client-secret-here
PDD_PID=your-pdd-pid-here

# 淘宝客API配置 (可选)
TB_APP_KEY=
TB_APP_SECRET=
TB_PID=

# 1688配置 (可选)
ALI_APP_KEY=
ALI_APP_SECRET=